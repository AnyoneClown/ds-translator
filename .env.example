# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
# COMMAND_PREFIX=!
# TRANSLATOR_ROLE=Translator

# Optional Settings
# AUTO_REDEEM_CHANNELS=123456789012345678,876543210987654321

# Database Configuration
# CockroachDB connection URL with asyncpg driver
# Format: cockroachdb+asyncpg://username:password@host:port/database
COCKROACHDB_URL=cockroachdb+asyncpg://postgres:password@host:26257/database-name

# OCR Configuration
# Kolosal AI OCR API Key for image text extraction
KOLOSAL_OCR_API_KEY=kol_your_kolosal_api_key_here

# Logging
LOG_LEVEL=INFO
